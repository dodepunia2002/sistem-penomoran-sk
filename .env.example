APP_NAME="Sistem Penomoran SK"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# DATABASE
# Pilih salah satu: SQLite (lokal) atau MySQL (Docker)
# ─────────────────────────────────────────────────────────────

# → LOCAL (SQLite — tanpa instalasi apapun):
DB_CONNECTION=sqlite

# → DOCKER (MySQL — aktifkan jika pakai docker compose):
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=sistem_sk
# DB_USERNAME=sk_user
# DB_PASSWORD=sk_password

# ─────────────────────────────────────────────────────────────
# SESSION & CACHE
# Pilih: file/database (lokal) atau redis (Docker)
# ─────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# ─────────────────────────────────────────────────────────────
# REDIS (aktif jika pakai Docker)
# ─────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────
# MAIL (default: log saja)
# ─────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@dishub-gianyar.go.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
