# ─────────────────────────────────────────────
#  Sistem Penomoran SK — .gitignore
# ─────────────────────────────────────────────

# ── Node / Frontend ───────────────────────────
/node_modules
/public/build
/public/hot
/public/storage

# ── PHP / Composer ────────────────────────────
/vendor
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php
.phpactor.json
Homestead.json
Homestead.yaml

# ── Laravel ───────────────────────────────────
/storage/*.key
/storage/pail
/bootstrap/cache/*.php

# ── Environment files ─────────────────────────
.env
.env.backup
.env.local
.env.testing
.env.production
# Keep committed (templates):
!.env.example
!.env.docker

# ── Docker ────────────────────────────────────
docker-compose.override.yml

# ── Database ──────────────────────────────────
/database/*.sqlite
/database/*.sqlite-journal

# ── Testing ───────────────────────────────────
.phpunit.result.cache
.phpunit.cache

# ── IDE / Editor ──────────────────────────────
.idea
.vscode
.zed
.nova
.fleet

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────
*.log

# ── Misc garbage ──────────────────────────────
routes.json
public/mix-manifest.json
mix-manifest.json
